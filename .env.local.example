# Supabase — get these from your project Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# SERVER-SIDE ONLY — never expose to the client, never use NEXT_PUBLIC_ prefix
SUPABASE_SECRET_KEY=sb_secret_...

# Secret salt used to hash IP addresses before storing them
IP_HASH_SALT=replace-with-a-random-secret-string

# Stripe — get these from dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) locally; set live keys in Vercel for production
STRIPE_SECRET_KEY=sk_test_...
