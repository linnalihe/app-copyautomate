# Supabase — get these from your project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# SERVER-SIDE ONLY — never expose to the client, never use NEXT_PUBLIC_ prefix
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Secret salt used to hash IP addresses before storing them
IP_HASH_SALT=replace-with-a-random-secret-string
